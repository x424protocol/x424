{
  "name": "x424",
  "version": "0.1.0",
  "description": "HTTP-native unique-human dependencies for users, agents, and APIs.",
  "license": "Apache-2.0",
  "homepage": "https://x424.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x424protocol/x424.git"
  },
  "bugs": {
    "url": "https://github.com/x424protocol/x424/issues"
  },
  "keywords": [
    "x424",
    "human-verification",
    "proof-of-personhood",
    "proof-of-humanity",
    "agents",
    "http"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./providers/world-id": {
      "types": "./dist/providers/world-id.d.ts",
      "import": "./dist/providers/world-id.js"
    },
    "./express": {
      "types": "./dist/api/router.d.ts",
      "import": "./dist/api/router.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "x424-mcp-server": "./dist/mcp/cli.js"
  },
  "files": [
    "dist",
    "conformance",
    "demo",
    "docs",
    "openapi",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "conformance": "vitest run test/provider-sdk.test.ts test/conformance.test.ts",
    "example": "tsx examples/http-flow.ts",
    "mcp": "tsx src/mcp/cli.ts",
    "mcp:http": "X424_MCP_TRANSPORT=http tsx src/mcp/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --dir test",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
