{
  "name": "x424",
  "version": "0.1.0",
  "description": "x424 makes unique humanity a native HTTP dependency—for users, agents, and APIs.",
  "license": "Apache-2.0",
  "homepage": "https://x424.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x424protocol/x424.git"
  },
  "bugs": {
    "url": "https://github.com/x424protocol/x424/issues"
  },
  "keywords": [
    "x424",
    "human-verification",
    "proof-of-personhood",
    "proof-of-humanity",
    "agents",
    "http",
    "http-424",
    "world-id",
    "x402"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./managed": {
      "types": "./dist/managed.d.ts",
      "import": "./dist/managed.js"
    },
    "./handoff": {
      "types": "./dist/handoff.d.ts",
      "import": "./dist/handoff.js"
    },
    "./x402": {
      "types": "./dist/x402.d.ts",
      "import": "./dist/x402.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./providers/world-id": {
      "types": "./dist/providers/world-id.d.ts",
      "import": "./dist/providers/world-id.js"
    },
    "./world": {
      "types": "./dist/providers/world-id.d.ts",
      "import": "./dist/providers/world-id.js"
    },
    "./providers/world-id/client": {
      "types": "./dist/providers/world-id-client.d.ts",
      "import": "./dist/providers/world-id-client.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./middleware": {
      "types": "./dist/middleware/resource.d.ts",
      "import": "./dist/middleware/resource.js"
    },
    "./postgres": {
      "types": "./dist/postgres/store.d.ts",
      "import": "./dist/postgres/store.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "x424-agent": "./dist/agent/cli.js",
    "x424-mcp-server": "./dist/mcp/cli.js",
    "x424-conformance": "./dist/conformance/cli.js"
  },
  "files": [
    "dist",
    "conformance",
    "demo",
    "deploy",
    "docs",
    "examples",
    "CHANGELOG.md",
    "openapi",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "conformance": "vitest run test/provider-sdk.test.ts test/conformance.test.ts && pnpm build && node dist/conformance/cli.js",
    "example": "tsx examples/http-flow.ts",
    "image:smoke": "node scripts/image-smoke.mjs",
    "mcp": "tsx src/mcp/cli.ts",
    "mcp:http": "X424_MCP_TRANSPORT=http tsx src/mcp/cli.ts",
    "quickstart": "node scripts/run-quickstart.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --dir test",
    "test:adopter-contract": "vitest run test/core.test.ts test/api.test.ts test/client.test.ts test/middleware.test.ts test/world-provider-request-conformance.test.ts test/security-regressions.test.ts",
    "release:check": "pnpm check && npm pack --dry-run",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@worldcoin/idkit-core": "^4.2.2",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "redis": "^6.1.0",
    "viem": "^2.55.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@x402/core": "^2.19.0",
    "@x402/evm": "^2.19.0",
    "@x402/express": "^2.19.0",
    "@x402/fetch": "^2.19.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
