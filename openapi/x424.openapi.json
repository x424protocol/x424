{
  "openapi": "3.1.0",
  "info": {
    "title": "x424 Unique-Human Dependency API",
    "version": "0.1.0",
    "description": "x424 makes unique humanity a native HTTP dependency—for users, agents, and APIs. This reference API issues and satisfies exact unique-human dependencies; a successful result is evidence for one bound dependency, not general identity or application authorization."
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin verifier deployment"
    }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/.well-known/x424-verifier": {
      "get": {
        "operationId": "getVerifierMetadata",
        "summary": "Fetch authenticated signed verifier metadata",
        "responses": {
          "200": {
            "description": "Signed x424-verifier-metadata+jws document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["token"],
                  "properties": {
                    "token": { "type": "string", "maxLength": 65536 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/requirements": {
      "post": {
        "operationId": "createHumanRequirement",
        "summary": "Create a short-lived unique-human dependency",
        "description": "Deployments must authenticate and authorize this endpoint. Exactly one configured source supplies provider-native request material: the self-hosted verifier generates it, or an authenticated adopter backend supplies signed material that the provider adapter validates. Provider signing keys are never submitted.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRequirement" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Dependency created. When x424Transport is header, HUMAN-REQUIRED carries the base64url requirement (≤8192 UTF-8 bytes). Larger requirements use body transport and omit HUMAN-REQUIRED.",
            "headers": {
              "HUMAN-REQUIRED": {
                "required": false,
                "schema": { "type": "string", "maxLength": 8192 }
              },
              "Cache-Control": {
                "schema": { "type": "string", "const": "no-store, private" }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["requirement", "x424Transport"],
                  "properties": {
                    "requirement": {
                      "$ref": "#/components/schemas/HumanRequirement"
                    },
                    "x424Transport": { "enum": ["header", "body"] }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "503": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/requirements/{dependencyId}": {
      "get": {
        "operationId": "getHumanRequirementState",
        "summary": "Read retained requirement state for an authenticated resource server",
        "parameters": [
          {
            "name": "dependencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "responses": {
          "200": {
            "description": "Retained server-issued dependency",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["requirement"],
                  "properties": {
                    "requirement": {
                      "$ref": "#/components/schemas/HumanRequirement"
                    }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Problem" }
        }
      },
      "delete": {
        "operationId": "deleteHumanRequirementState",
        "summary": "Delete retained requirement state after acceptance",
        "parameters": [
          {
            "name": "dependencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "responses": {
          "204": { "description": "Deleted or already absent" }
        }
      }
    },
    "/v1/requirements/{dependencyId}/verify": {
      "post": {
        "operationId": "verifyHumanProof",
        "summary": "Verify the selected provider proof and satisfy a dependency",
        "description": "Provider-native proof is handled inside the selected adapter. The response omits provider nullifiers and raw proofs.",
        "parameters": [
          {
            "name": "dependencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/HumanProofSubmission" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Human dependency satisfied. HUMAN-RESULT is an x424-result+jws token.",
            "headers": {
              "HUMAN-RESULT": {
                "required": true,
                "schema": { "type": "string", "maxLength": 65536 }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["result", "token"],
                  "properties": {
                    "result": { "$ref": "#/components/schemas/HumanResult" },
                    "token": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "404": { "$ref": "#/components/responses/Problem" },
          "422": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/requirements/{dependencyId}/handoffs": {
      "post": {
        "operationId": "startHumanHandoff",
        "summary": "Start a provider-neutral brokered human handoff",
        "description": "Starts one short-lived handoff for the exact dependency nonce and accepted provider method. Provider session material remains encrypted inside the verifier. The returned access token is a bearer capability and must not be logged.",
        "security": [],
        "parameters": [
          {
            "name": "dependencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StartHumanHandoff" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pending handoff and its short-lived bearer capability",
            "headers": {
              "Cache-Control": {
                "schema": { "type": "string", "const": "no-store, private" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StartedHumanHandoff" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "429": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/handoffs/{handoffId}": {
      "get": {
        "operationId": "getHumanHandoff",
        "summary": "Poll a brokered handoff",
        "description": "Returns only protocol handoff state. Completion returns a signed HUMAN-PROOF and never the provider-native proof.",
        "security": [{ "handoffCapability": [] }],
        "parameters": [
          {
            "name": "handoffId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "responses": {
          "200": {
            "description": "Current handoff state",
            "headers": {
              "Cache-Control": {
                "schema": { "type": "string", "const": "no-store, private" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HumanHandoff" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Problem" }
        }
      },
      "delete": {
        "operationId": "cancelHumanHandoff",
        "summary": "Cancel a brokered handoff",
        "security": [{ "handoffCapability": [] }],
        "parameters": [
          {
            "name": "handoffId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "responses": {
          "204": { "description": "Handoff cancelled" },
          "401": { "$ref": "#/components/responses/Problem" },
          "404": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/results/{resultId}/consume": {
      "post": {
        "operationId": "consumeHumanResult",
        "summary": "Atomically consume one result for an authenticated resource server",
        "parameters": [
          {
            "name": "resultId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["expiresAt"],
                "properties": {
                  "expiresAt": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Atomic consumption outcome",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["consumed"],
                  "properties": { "consumed": { "type": "boolean" } }
                }
              }
            }
          }
        }
      }
    },
    "/v1/results/{resultId}/acceptances": {
      "post": {
        "operationId": "acceptHumanResultOperation",
        "summary": "Atomically accept a result for one idempotent mutation",
        "description": "The same result may be accepted again only for the same operationId and requestDigest. A different operation, method, URI, body, or caller-bound digest returns replay.",
        "parameters": [
          {
            "name": "resultId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "maxLength": 200 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResultAcceptance" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Atomic acceptance outcome",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["status"],
                  "properties": {
                    "status": { "enum": ["new", "same_operation", "replay"] }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/healthz": {
      "get": {
        "operationId": "getHealth",
        "summary": "Read reference verifier health",
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["status", "protocol", "version"],
                  "properties": {
                    "status": { "const": "ok" },
                    "protocol": { "const": "x424" },
                    "version": { "const": "0.1" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Deployment-issued caller authentication. This is separate from HUMAN-PROOF."
      },
      "handoffCapability": {
        "type": "http",
        "scheme": "bearer",
        "description": "Short-lived per-handoff bearer capability. Verifiers store only its digest and exclude it from logs and telemetry."
      }
    },
    "responses": {
      "Problem": {
        "description": "RFC 9457-style problem response",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      }
    },
    "schemas": {
      "Binding": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value"],
        "properties": {
          "kind": { "enum": ["request", "wallet", "agent_key", "session"] },
          "value": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      },
      "HumanMethodRequirement": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "providerId",
          "methodId",
          "descriptorVersion",
          "acceptedScopeKinds"
        ],
        "properties": {
          "providerId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "methodId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "descriptorVersion": { "type": "string" },
          "assuranceLevel": { "type": "string" },
          "acceptedScopeKinds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "enum": ["global", "relying_party", "action", "session"]
            }
          },
          "maximumProofAgeSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400
          },
          "verificationModes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": { "enum": ["backend", "offchain", "onchain", "hybrid"] }
          }
        }
      },
      "CreateRequirement": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "purpose",
          "method",
          "uri",
          "audience",
          "binding",
          "accepts"
        ],
        "properties": {
          "purpose": { "type": "string", "minLength": 1, "maxLength": 200 },
          "method": { "type": "string", "minLength": 1, "maxLength": 20 },
          "uri": { "type": "string", "format": "uri", "maxLength": 2048 },
          "audience": { "type": "string", "format": "uri", "maxLength": 2048 },
          "body": {
            "description": "Deprecated. Plain JSON object/array only. Prefer bodyInput."
          },
          "bodyInput": {
            "$ref": "#/components/schemas/RequestBodyDigestInput"
          },
          "binding": { "$ref": "#/components/schemas/Binding" },
          "accepts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": { "$ref": "#/components/schemas/HumanMethodRequirement" }
          },
          "providerRequests": {
            "type": "object",
            "maxProperties": 10,
            "description": "Opaque adopter-signed provider request material keyed by providerId:methodId. Accepted only in authenticated issuer mode and validated by the selected provider adapter. Never contains a provider signing key.",
            "additionalProperties": true
          },
          "ttlSeconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 900,
            "default": 300
          }
        }
      },
      "HumanRequirement": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x424Version",
          "dependencyId",
          "purpose",
          "resource",
          "nonce",
          "binding",
          "createdAt",
          "expiresAt",
          "accepts"
        ],
        "properties": {
          "x424Version": { "const": "0.1" },
          "dependencyId": { "type": "string" },
          "purpose": { "type": "string" },
          "resource": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "uri", "audience", "requestDigest"],
            "properties": {
              "method": { "type": "string" },
              "uri": { "type": "string", "format": "uri" },
              "audience": { "type": "string", "format": "uri" },
              "requestDigest": {
                "type": "string",
                "pattern": "^sha256:[A-Za-z0-9_-]{43}$"
              }
            }
          },
          "nonce": { "type": "string" },
          "binding": { "$ref": "#/components/schemas/Binding" },
          "createdAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "accepts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": { "$ref": "#/components/schemas/HumanMethodRequirement" }
          },
          "providerRequests": {
            "type": "object",
            "propertyNames": { "maxLength": 201 },
            "additionalProperties": true
          }
        }
      },
      "HumanProofSubmission": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x424Version",
          "dependencyId",
          "providerId",
          "methodId",
          "binding",
          "nativeProof"
        ],
        "properties": {
          "x424Version": { "const": "0.1" },
          "dependencyId": { "type": "string" },
          "providerId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "methodId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "binding": { "$ref": "#/components/schemas/Binding" },
          "nativeProof": {
            "description": "Opaque provider-native proof; never log this field."
          }
        }
      },
      "StartHumanHandoff": {
        "type": "object",
        "additionalProperties": false,
        "required": ["nonce", "providerId", "methodId"],
        "properties": {
          "nonce": { "type": "string", "minLength": 1, "maxLength": 512 },
          "providerId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "methodId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          }
        }
      },
      "HandoffPresentation": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "uri"],
        "properties": {
          "kind": { "const": "uri" },
          "uri": { "type": "string", "format": "uri", "maxLength": 4096 },
          "userCode": { "type": "string", "maxLength": 100 }
        }
      },
      "StartedHumanHandoff": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "handoffId",
          "accessToken",
          "status",
          "providerId",
          "methodId",
          "presentation",
          "expiresAt",
          "pollAfterMs"
        ],
        "properties": {
          "handoffId": { "type": "string", "maxLength": 200 },
          "accessToken": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{43}$",
            "description": "Secret bearer capability; never log or persist in plaintext."
          },
          "status": { "const": "pending" },
          "providerId": { "type": "string" },
          "methodId": { "type": "string" },
          "presentation": {
            "$ref": "#/components/schemas/HandoffPresentation"
          },
          "expiresAt": { "type": "string", "format": "date-time" },
          "pollAfterMs": { "type": "integer", "minimum": 500, "maximum": 10000 }
        }
      },
      "HumanHandoff": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["handoffId", "status", "pollAfterMs", "expiresAt"],
            "properties": {
              "handoffId": { "type": "string" },
              "status": { "const": "pending" },
              "pollAfterMs": { "type": "integer" },
              "expiresAt": { "type": "string", "format": "date-time" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["handoffId", "status", "humanProof", "expiresAt"],
            "properties": {
              "handoffId": { "type": "string" },
              "status": { "const": "completed" },
              "humanProof": { "type": "string", "maxLength": 65536 },
              "expiresAt": { "type": "string", "format": "date-time" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["handoffId", "status", "code", "expiresAt"],
            "properties": {
              "handoffId": { "type": "string" },
              "status": { "const": "failed" },
              "code": { "type": "string", "maxLength": 100 },
              "expiresAt": { "type": "string", "format": "date-time" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["handoffId", "status", "expiresAt"],
            "properties": {
              "handoffId": { "type": "string" },
              "status": { "enum": ["expired", "cancelled"] },
              "expiresAt": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },
      "ResultAcceptance": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operationId", "requestDigest", "expiresAt"],
        "properties": {
          "operationId": { "type": "string", "minLength": 1, "maxLength": 512 },
          "requestDigest": {
            "type": "string",
            "pattern": "^sha256:[A-Za-z0-9_-]{43}$"
          },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "HumanResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x424Version",
          "resultId",
          "dependencyId",
          "satisfied",
          "purpose",
          "audience",
          "requestDigest",
          "binding",
          "providerId",
          "methodId",
          "descriptorVersion",
          "pairwiseHumanId",
          "uniquenessScope",
          "verificationMode",
          "proofDigest",
          "claim",
          "nonClaims",
          "verifiedAt",
          "issuedAt",
          "expiresAt"
        ],
        "properties": {
          "x424Version": { "const": "0.1" },
          "resultId": { "type": "string" },
          "dependencyId": { "type": "string" },
          "satisfied": { "const": true },
          "purpose": { "type": "string" },
          "audience": { "type": "string", "format": "uri" },
          "requestDigest": {
            "type": "string",
            "pattern": "^sha256:[A-Za-z0-9_-]{43}$"
          },
          "binding": { "$ref": "#/components/schemas/Binding" },
          "providerId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "methodId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,99}$"
          },
          "descriptorVersion": { "type": "string" },
          "assuranceLevel": { "type": "string" },
          "pairwiseHumanId": { "type": "string", "pattern": "^x424_human_" },
          "uniquenessScope": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id"],
            "properties": {
              "kind": {
                "enum": ["global", "relying_party", "action", "session"]
              },
              "id": { "type": "string" }
            }
          },
          "verificationMode": {
            "enum": ["backend", "offchain", "onchain", "hybrid"]
          },
          "proofDigest": {
            "type": "string",
            "pattern": "^sha256:[A-Za-z0-9_-]{43}$"
          },
          "claim": { "type": "string" },
          "nonClaims": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "verifiedAt": { "type": "string", "format": "date-time" },
          "issuedAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "stateReferences": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Problem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title", "status", "detail"],
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string", "maxLength": 200 },
          "code": { "type": "string" }
        }
      },
      "RequestBodyDigestInput": {
        "description": "Explicit ADR-0002 body digest kinds. Never infer Blob/Date/class as JSON. Stream without precomputed fails closed and is not accepted on this wire API.",
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": { "kind": { "const": "absent" } }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": { "kind": { "const": "empty" } }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
              "kind": { "const": "json" },
              "value": {
                "description": "Plain JSON object or array only"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "bytesBase64url"],
            "properties": {
              "kind": { "const": "opaque" },
              "bytesBase64url": {
                "type": "string",
                "description": "Exact body bytes, strict unpadded base64url"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "bodyDigest"],
            "properties": {
              "kind": { "const": "precomputed" },
              "bodyDigest": {
                "type": "string",
                "pattern": "^sha256:[A-Za-z0-9_-]{43}$"
              }
            }
          }
        ]
      },
      "HumanRequiredProblem": {
        "description": "Resource-server 424 challenge body (see schemas/human-required-problem-0.1.schema.json)",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "title",
          "status",
          "detail",
          "dependencyId",
          "x424Transport"
        ],
        "properties": {
          "type": { "const": "https://x424.org/problems/human-required" },
          "title": { "const": "Unique human required" },
          "status": { "const": 424 },
          "detail": { "type": "string" },
          "dependencyId": { "type": "string" },
          "x424Transport": { "enum": ["header", "body"] },
          "requirement": { "$ref": "#/components/schemas/HumanRequirement" }
        },
        "allOf": [
          {
            "if": { "properties": { "x424Transport": { "const": "body" } } },
            "then": { "required": ["requirement"] }
          },
          {
            "if": { "properties": { "x424Transport": { "const": "header" } } },
            "then": { "not": { "required": ["requirement"] } }
          }
        ]
      }
    }
  }
}
